# Copy this file to .env (in the same dir) and fill in real values.
# .env is gitignored — never commit real tokens.
# Loaded by epic_fitness_check.zsh when --mcpi mode is active.

JIRA_URL="https://jira.example.com"
JIRA_PERSONAL_TOKEN="REPLACE_ME"
JIRA_SSL_VERIFY="true"

CONFLUENCE_URL="https://confluence.example.com"
CONFLUENCE_PERSONAL_TOKEN="REPLACE_ME"
CONFLUENCE_SSL_VERIFY="true"
